{
  "name": "splatty",
  "version": "0.1.2",
  "description": "Splatty — Syncplay-compatible watch-together client with a terminal (Ink) GUI",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "splatty": "dist/bin/splatty-client.js"
  },
  "files": [
    "dist",
    "resources"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atagulalan/splatty.git"
  },
  "homepage": "https://github.com/atagulalan/splatty#readme",
  "scripts": {
    "server": "tsx src/bin/syncplay-server.ts",
    "client": "tsx src/bin/splatty-client.tsx",
    "splatty": "tsx src/bin/splatty-client.tsx",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "tsx test/roomManager.test.ts && tsx test/commandRegistry.test.ts && tsx test/completion.test.ts && tsx test/autoplay.test.ts && tsx test/smoke.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ini": "^4.1.3",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/ini": "^4.1.1",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "prettier": "3.9.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
